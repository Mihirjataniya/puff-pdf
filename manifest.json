{
  "manifest_version": 3,
  "name": "PDF Draw — Annotate & Highlight",
  "description": "Draw, highlight, and mark up PDFs in your browser. Export flattened PDFs that work anywhere.",
  "version": "0.1.0",
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "PDF Draw",
    "default_popup": "popup.html"
  },
  "permissions": [
    "storage",
    "webNavigation",
    "webRequest",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "viewer.html",
        "viewer.css",
        "lib/*",
        "src/*",
        "icons/*"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; worker-src 'self'"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "pdf-draw@glitchover.com",
      "strict_min_version": "121.0"
    }
  }
}
